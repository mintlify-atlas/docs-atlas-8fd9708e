  "keyFeatures": [
    "Support for 1600+ languages including hundreds never covered by ASR technology",
    "Multiple model families: W2V SSL, CTC ASR, and LLM-based ASR with 300M to 7B parameters",
    "Zero-shot learning with in-context examples for unseen languages",
    "Language conditioning for improved transcription accuracy",
    "Unlimited audio length support with segmented processing",
    "Comprehensive training and evaluation recipes with fairseq2",
    "Parquet-based data pipeline for massive multilingual datasets",
    "HuggingFace dataset integration with facebook/omnilingual-asr-corpus"
  ],
